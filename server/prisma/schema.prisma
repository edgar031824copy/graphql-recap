generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id          String  @id @default(cuid())
  name        String
  description String?
  jobs        Job[]
  users       User[]
}

model Job {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id])
  companyId   String
}

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  password  String
  company   Company @relation(fields: [companyId], references: [id])
  companyId String
}
